# =====================================================
# VARIABLES DE ENTORNO PARA KALLMAX
# =====================================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo como .env para desarrollo local
# 2. En Railway, configura estas variables en el Dashboard
# 3. NUNCA subas el archivo .env a Git
#
# =====================================================

# Flask Configuration
SECRET_KEY=genera-tu-clave-con-generar_secret_key.py
DEBUG=False

# Server Configuration (Railway lo asigna automáticamente)
# PORT=8000

# Database Configuration (si usas MySQL)
# DB_HOST=tu-host-mysql
# DB_PORT=3306
# DB_USER=tu-usuario
# DB_PASSWORD=tu-password
# DB_NAME=kallmax_db

# Railway Environment (automático)
# RAILWAY_ENVIRONMENT=production
